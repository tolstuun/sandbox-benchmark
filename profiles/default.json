{
  "profile_id": "default",
  "name": "Default Profile",
  "version": 1,
  "checks": [
    "demo.runner_start",
    "demo.profile_loaded",
    "env.cpu.logical_processor_count",
    "env.memory.total_physical_mb",
    "env.storage.system_drive_total_gb"
  ],
  "output_directory": "logs",
  "console_logging_enabled": true,
  "json_logging_enabled": true
}
